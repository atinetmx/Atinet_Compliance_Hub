# ============================================
# BASES DE DATOS - LISTAS NEGRAS (OFAC/SAT)
# ============================================
# Arquitectura: Doble conexión para sincronización incremental
#
# CONEXIONES LOCALES (BD Local):
#   - Usadas para todas las búsquedas (velocidad máxima)
#   - Réplicas sincronizadas desde Hostgator
#
# CONEXIONES REMOTAS (Hostgator):
#   - Usadas SOLO para sincronización incremental
#   - Se ejecuta via comando: php artisan blacklists:sync
#   - Trae únicamente registros nuevos (comparativa delta)

# BD Aplicativos - LOCAL (operaciones normales)
DB_APLICATIVOS_DATABASE=atinet65_aplicativos

# BD Lista OFAC - LOCAL (búsquedas rápidas)
DB_OFAC_DATABASE=atinet65_listasofac

# BD Lista SAT - LOCAL (búsquedas rápidas)
DB_SAT_DATABASE=atinet65_listassat

# ==========================================
# CONEXIONES REMOTAS (Hostgator)
